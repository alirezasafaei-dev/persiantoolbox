# Application
NEXT_PUBLIC_SITE_URL=https://persiantoolbox.ir
NEXT_PUBLIC_SITE_NAME="جعبه ابزار فارسی"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/analytics
ANALYTICS_STORAGE=postgres
ANALYTICS_DATA_DIR=var/analytics
ANALYTICS_INGEST_SECRET=
ANALYTICS_MAX_BODY_BYTES=262144
ANALYTICS_RATE_LIMIT=120
ANALYTICS_RATE_WINDOW_MS=60000

# App storage & auth
APP_DATA_DIR=var/app
DATABASE_URL=postgresql://user:password@localhost:5432/persian_tools
REDIS_URL=redis://localhost:6379
SESSION_TTL_DAYS=7
SUBSCRIPTION_WEBHOOK_SECRET=
ADMIN_EMAIL_ALLOWLIST=admin@example.com
OPS_DASHBOARD_TOKEN=

# Payment Gateway Configuration
PAYMENT_BASE_URL=https://payment.persiantoolbox.ir
PAYMENT_WEBHOOK_SECRET=
ZARINPAL_MERCHANT_ID=
ZARINPAL_MODE=sandbox

# Support Links
NEXT_PUBLIC_SUPPORT_ONETIME_URL=
NEXT_PUBLIC_SUPPORT_MONTHLY_URL=
NEXT_PUBLIC_SUPPORT_SPONSOR_URL=

# Developer Attribution Links (Footer + Admin)
DEVELOPER_NAME="علیرضا صفایی"
DEVELOPER_BRAND_TEXT="این وب‌سایت توسط علیرضا صفایی توسعه داده شده است."
ORDER_URL=
PORTFOLIO_URL=

# AI Assistant (Optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_BASE_URL=

# Feature Flags (all enabled by default in v6.4.0)
# To disable a feature, set its value to 0
FEATURE_AUTH_ENABLED=1
FEATURE_ACCOUNT_ENABLED=1
FEATURE_SUBSCRIPTION_ENABLED=1
FEATURE_PLANS_ENABLED=1
FEATURE_CHECKOUT_ENABLED=1
FEATURE_DASHBOARD_ENABLED=1
FEATURE_HISTORY_ENABLED=1
FEATURE_HISTORY_SHARE_ENABLED=1
FEATURE_SUPPORT_ENABLED=1
FEATURE_DEVELOPERS_ENABLED=1
FEATURE_ADS_ENABLED=1
FEATURE_ADMIN_SITE_SETTINGS_ENABLED=1
FEATURE_ADMIN_MONETIZATION_ENABLED=1
FEATURE_SUBSCRIPTION_ROADMAP_ENABLED=1

# Ops window scheduler (optional)
OPS_WINDOW_REPEAT=6
OPS_WINDOW_INTERVAL_MS=30000
OPS_DEGRADED_WEBHOOK=

# Web Push Notifications (VAPID)
# Generate keys: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@persiantoolbox.ir
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
