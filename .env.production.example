# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# PersianToolbox v6.4.0
# ============================================

# ============================================
# DOMAIN CONFIGURATION
# ============================================
NEXT_PUBLIC_SITE_URL=https://persiantoolbox.ir
NEXT_PUBLIC_SITE_NAME=جعبه ابزار فارسی
NEXT_PUBLIC_SITE_TAGLINE=ابزارهای آنلاین فارسی، سریع و امن
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:persiantoolbox.ir

# ============================================
# DATABASE CONFIGURATION (PostgreSQL required)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/persian_tools

# ============================================
# AUTH & SESSIONS
# ============================================
SESSION_TTL_DAYS=7
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# ============================================
# PAYMENT GATEWAY (Zarinpal)
# ============================================
# Zarinpal verified pay subdomain (DNS CNAME pay → zpc.zarinpal.com)
PAYMENT_BASE_URL=https://pay.persiantoolbox.ir
PAYMENT_WEBHOOK_SECRET=
ZARINPAL_MERCHANT_ID=
ZARINPAL_MODE=production
ZARINPAL_CALLBACK_URL=https://persiantoolbox.ir/api/payments/callback

# ============================================
# FEATURE FLAGS
# All features enabled by default in v6.4.0
# ============================================
FEATURE_AUTH_ENABLED=1
FEATURE_ACCOUNT_ENABLED=1
FEATURE_SUBSCRIPTION_ENABLED=1
FEATURE_PLANS_ENABLED=1
FEATURE_CHECKOUT_ENABLED=1
FEATURE_DASHBOARD_ENABLED=1
FEATURE_HISTORY_ENABLED=1
FEATURE_HISTORY_SHARE_ENABLED=1
FEATURE_SUPPORT_ENABLED=1
FEATURE_DEVELOPERS_ENABLED=1
FEATURE_ADS_ENABLED=1
FEATURE_ADMIN_SITE_SETTINGS_ENABLED=1
FEATURE_ADMIN_MONETIZATION_ENABLED=1
FEATURE_SUBSCRIPTION_ROADMAP_ENABLED=1

# ============================================
# OPS
# ============================================
OPS_DASHBOARD_TOKEN=
OPS_DEGRADED_WEBHOOK=

# ============================================
# ANALYTICS (Optional)
# ============================================
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/analytics
# Opt-in Plausible pilot. The script URL is public but must come from Site Installation.
NEXT_PUBLIC_PLAUSIBLE_ENABLED=0
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
ANALYTICS_STORAGE=postgres
ANALYTICS_DATA_DIR=var/analytics
ANALYTICS_INGEST_SECRET=
ANALYTICS_MAX_BODY_BYTES=262144
ANALYTICS_RATE_LIMIT=120
ANALYTICS_RATE_WINDOW_MS=60000

# ============================================
# DEVELOPER ATTRIBUTION (Optional)
# ============================================
DEVELOPER_NAME="علیرضا صفایی"
DEVELOPER_BRAND_TEXT="این وب‌سایت توسط علیرضا صفایی توسعه داده شده است."
ORDER_URL=
PORTFOLIO_URL=

# ============================================
# AI ASSISTANT (Optional)
# ============================================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_BASE_URL=

# ============================================
# PERFORMANCE
# ============================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
LOG_LEVEL=info
